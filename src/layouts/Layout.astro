---
import { WhatsAppFAB } from "@/components/WhatsAppFAB";
import { BUSINESS } from "@/lib/constants";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = `${BUSINESS.name} - ${BUSINESS.tagline}`, 
  description = BUSINESS.description
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(`${import.meta.env.BASE_URL}/assets/hero.png`, Astro.site);
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/assets/icon.png`} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Google Analytics (GA4) -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${BUSINESS.analyticsId}`} is:inline></script>
    <script is:inline define:vars={{ analyticsId: BUSINESS.analyticsId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', analyticsId);
    </script>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Schema.org Local Business -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": BUSINESS.name,
      "image": socialImageURL.toString(),
      "description": description,
      "servesCuisine": "Indonesian",
      "priceRange": "Rp",
      "telephone": BUSINESS.phone,
      "url": Astro.site?.toString() || "https://warteg-barokah.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": BUSINESS.address,
        "addressLocality": "Jakarta Timur",
        "postalCode": "13950",
        "addressCountry": "ID"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -6.1956116,
        "longitude": 106.921431
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"
        ],
        "opens": "07:00",
        "closes": "22:00"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "153"
      }
    })} />
  </head>
  <body class="min-h-screen bg-white dark:bg-zinc-950 font-sans antialiased selection:bg-brand/10 selection:text-brand transition-colors duration-300">
    <!-- Skip to content link for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-[100] bg-brand text-white px-6 py-3 rounded-full font-bold shadow-xl">
      Skip ke konten utama
    </a>

    <div id="main-content">
      <slot />
    </div>

    <WhatsAppFAB client:idle />
  </body>
</html>

<style is:global>
  :root {
    --brand: #912727;
  }
  
  html {
    scroll-behavior: smooth;
  }

  body::-webkit-scrollbar {
    width: 10px;
  }

  body::-webkit-scrollbar-track {
    background: transparent;
  }

  body::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
    border: 3px solid transparent;
    background-clip: content-box;
  }

  .dark body::-webkit-scrollbar-thumb {
    background: #1e293b;
  }

  body::-webkit-scrollbar-thumb:hover {
    background: var(--brand);
    background-clip: content-box;
  }
</style>
